{
  "name": "packages",
  "version": "0.2.0",
  "description": "My mono-repo for a bunch of small NPM/bun packages",
  "main": "index.js",
  "repository": "https://github.com/kevinfrei/packages.git",
  "author": "Kevin Frei <kevinfrei@hotmail.com>",
  "license": "Unlicense",
  "workspaces": {
    "packages": [
      "modules/agnostic/*",
      "modules/node/*",
      "modules/server/*",
      "modules/www/*"
    ],
    "catalog": {
      "@fluentui/react": "^8.125.5",
      "@fluentui/react-components": "^9.73.8",
      "@fluentui/react-hooks": "^8.10.2",
      "@freik/is-hidden-file": "^1.13.2",
      "debug": "^4.4.0",
      "music-metadata": "^11.12.3",
      "react": "^19.2.4",
      "react-dom": "^19.2.4"
    },
    "catalogs": {
      "dev": {
        "@eslint/eslintrc": "^3.3.5",
        "@types/bun": "^1.3.11",
        "@types/debug": "^4.1.13",
        "@types/node": "^25.5.0",
        "@types/react-test-renderer": "^19.1.0",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "@typescript-eslint/parser": "^8.57.2",
        "babel-eslint": "^10.1.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.1",
        "typedoc": "^0.28.7",
        "typedoc-plugin-markdown": "^4.7.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.57.2",
        "@happy-dom/global-registrator": "^20.8.9",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "happy-dom": "^20.8.9",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-scripts": "^5.0.1",
        "@freik/workspace": "^0.8.1",
        "esbuild": "^0.28.0",
        "madge": "^8.0.0",
        "prettier": "^3.8.3"
      }
    }
  },
  "scripts": {
    "prepare": "bunx simple-git-hooks",
    "release": "bun runall release",
    "build": "bun runall build",
    "test": "bun runall test",
    "justtest": "bun runall justtest",
    "typechk": "bun runall typechk",
    "lint": "bun runflat lint",
    "runall": "bun serial bun run",
    "runflat": "bun serial bun run",
    "forall": "tools workspace",
    "forflat": "tools workspace --no-deps",
    "serial": "tools workspace -s",
    "format": "tools format bun",
    "pub2npm": "bun serial npm publish --access=public",
    "bun2npm": "bun serial bun publish --access public",
    "prep4npm": "tools workspace -f",
    "done4npm": "tools workspace -c",
    "bumpver": "tools workspace -v",
    "verpatch": "bun run bumpver patch",
    "verminor": "bun run bumpver minor"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/bun": "^1.3.11",
    "@types/debug": "^4.1.13",
    "@types/node": "^25.5.0",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "babel-eslint": "^10.1.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.1",
    "typedoc": "^0.28.7",
    "typedoc-plugin-markdown": "^4.7.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "@happy-dom/global-registrator": "^20.8.9",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "happy-dom": "^20.8.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-scripts": "^5.0.1",
    "@freik/workspace": "^0.8.1",
    "esbuild": "^0.28.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.3"
  },
  "peerDependencies": {
    "@fluentui/react": "^8.125.5",
    "@fluentui/react-components": "^9.73.8",
    "@fluentui/react-hooks": "^8.10.2",
    "@freik/is-hidden-file": "^1.13.2",
    "debug": "^4.4.0",
    "music-metadata": "^11.12.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run format",
    "pre-push": "bun run build && bun run test"
  }
}
